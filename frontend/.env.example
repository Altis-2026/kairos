# Copy this file to frontend/.env and fill in your values.
# Vite only exposes variables prefixed with VITE_ to the browser.

# REQUIRED — the globe will not render without this
VITE_MAPBOX_TOKEN=pk.eyJ1-your-mapbox-public-token

# REQUIRED — where the FastAPI backend is running
VITE_API_BASE_URL=http://localhost:8000

# OPTIONAL — enables Google sign-in. Leave blank to run without auth.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
