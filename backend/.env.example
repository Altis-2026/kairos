# Copy this file to backend/.env and fill in your values.

# REQUIRED — your Google Cloud project ID (the one registered with Earth Engine)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# REQUIRED for natural language queries (/query). Direct /analyze works without it.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OPTIONAL — Redis for background jobs. Leave as-is; the API falls back to
# synchronous execution automatically when Redis is not running.
REDIS_URL=redis://localhost:6379

# OPTIONAL — set in production to your deployed frontend URL for CORS
# (also used for reproducible-pack links in Janus)
# FRONTEND_ORIGIN=https://your-app.web.app

# OPTIONAL — Janus mentor uses OpenRouter (same key as the chat).
# OPENROUTER_API_KEY=sk-or-your-key-here

# OPTIONAL — a contact email for the OpenAlex "polite pool" (faster literature
# search in Janus). Any email works.
# OPENALEX_MAILTO=you@example.com

# OPTIONAL — NASA Earthdata Login bearer token. NOT needed for any current
# analysis; reserved for future Sentinel-1 SLC / InSAR access via ASF. Set it
# here (never commit the value) to make Janus report InSAR-readiness.
# EARTHDATA_TOKEN=your-earthdata-bearer-token

# OPTIONAL — Janus proactive monitoring scheduler (default on).
# JANUS_WATCH_ENABLED=1
# JANUS_WATCH_INTERVAL_HOURS=12
